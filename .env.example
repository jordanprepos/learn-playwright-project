# Slack integration for reading OTPs from the #bento-bot channel
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_OTP_CHANNEL_ID=C0XXXXXXXXX

# Google Sheets integration for writing test results (service account)
# Share the target spreadsheet with GOOGLE_SHEETS_CLIENT_EMAIL as an Editor.
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
