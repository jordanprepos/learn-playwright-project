# Slack integration for reading OTPs from the #bento-bot channel
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_OTP_CHANNEL_ID=C0XXXXXXXXX

# MySQL database connectivity (read-only verification of test data)
# Point this at a dedicated test/staging database — never production.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your-db-user
MYSQL_PASSWORD=your-db-password
MYSQL_DATABASE=your-database-name
MYSQL_SSL=false
